{
  "name": "fl-lottery-monitor",
  "version": "1.0.0",
  "description": "Florida Lottery YouTube channel monitor — captures draw results and emails them",
  "main": "src/monitor.js",
  "scripts": {
    "start": "node src/monitor.js",
    "dev": "nodemon src/monitor.js",
    "pm2:start": "pm2 start src/monitor.js --name fl-lottery-monitor --log logs/pm2.log",
    "pm2:stop": "pm2 stop fl-lottery-monitor",
    "pm2:restart": "pm2 restart fl-lottery-monitor",
    "pm2:status": "pm2 status fl-lottery-monitor",
    "pm2:logs": "pm2 logs fl-lottery-monitor"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "nodemailer": "^6.9.14"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
